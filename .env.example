# Скопируй этот файл в .env и заполни своими значениями.
# Файл .env не должен попадать в git (см. .gitignore) — именно там
# хранятся все секреты и реальные адреса RSS-источников.

# ====================== Telegram ======================

# Токен бота, полученный от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Твой личный числовой Telegram ID. Бот будет отвечать ТОЛЬКО этому ID,
# все остальные пользователи полностью игнорируются.
# Узнать свой ID можно, например, у бота @userinfobot.
TELEGRAM_ALLOWED_USER_ID=123456789

# ====================== Gemini (Google GenAI) ======================

# API-ключ, получить в Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Необязательно: конкретная модель Gemini (по умолчанию gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# ====================== RSS-ленты ======================

# Ровно 10 переменных под RSS-ленты. Заполняй только нужные, остальные
# оставь пустыми. Благодаря этому в коде и в репозитории нет ни одного
# реального адреса источника — только имена переменных.
RSS_FEED_1=
RSS_FEED_2=
RSS_FEED_3=
RSS_FEED_4=
RSS_FEED_5=
RSS_FEED_6=
RSS_FEED_7=
RSS_FEED_8=
RSS_FEED_9=
RSS_FEED_10=

# Сколько свежих новостей максимум брать с каждой ленты за один прогон
MAX_ITEMS_PER_FEED=5

# Учитывать только новости не старше N часов
NEWS_LOOKBACK_HOURS=24

# Сколько дней хранить ссылки уже показанных новостей (антидубликат)
SEEN_NEWS_RETENTION_DAYS=14

# ====================== Погода (Open-Meteo, ключ не нужен) ======================

WEATHER_LATITUDE=56.0184
WEATHER_LONGITUDE=92.8672

# ====================== Расписание автоматических рассылок ======================

# Часовой пояс в формате IANA, например Asia/Krasnoyarsk, Europe/Moscow
TIMEZONE=Asia/Krasnoyarsk

# Время ежедневной отправки в формате ЧЧ:ММ (24ч), по часовому поясу TIMEZONE
DIGEST_TIME=08:00
WEATHER_TIME=07:30

# Включить/выключить автоматическую ежедневную отправку (true/false)
AUTO_NEWS_ENABLED=true
AUTO_WEATHER_ENABLED=true

# ====================== Логирование ======================

LOG_LEVEL=INFO
